@dataclass(kw_only=True)
class ShadowingEnvCfg(InstinctLabRLEnvCfg):
    """Configuration for the shadowing environment."""

    scene: ShadowingSceneCfg = field(default_factory=lambda: ShadowingSceneCfg(num_envs=4096))
    actions: ActionsCfg = field(default_factory=lambda: ActionsCfg())
    observations: ObservationsCfg = field(default_factory=lambda: ObservationsCfg())
    commands: dict = field(default_factory=make_commands)
    rewards: SingleRewardsCfg = field(default_factory=lambda: SingleRewardsCfg())
    events: EventCfg = field(default_factory=lambda: EventCfg())
    curriculum: CurriculumCfg = field(default_factory=lambda: CurriculumCfg())
    terminations: TerminationCfg = field(default_factory=lambda: TerminationCfg())
    monitors: MonitorCfg = field(default_factory=lambda: MonitorCfg())

    def __post_init__(self):
        # general settings
        self.decimation = 4
        self.episode_length_s = 10.0
        # simulation settings
        self.sim.mujoco.timestep = 1.0 / 50.0 / self.decimation
        if hasattr(self.sim, "render_interval"):
            self.sim.render_interval = self.decimation
        if hasattr(self.sim, "physics_material"):
            self.sim.physics_material = self.scene.terrain.physics_material
        if hasattr(self.sim, "physx"):
            self.sim.physx.gpu_max_rigid_patch_count = 10 * 2**15

        self.actions = manager_terms_to_dict(self.actions)
        # commands is already a dict, no need to convert
        self.observations = manager_terms_to_dict(self.observations)
        if isinstance(self.rewards, MultiRewardCfg):
            for group_name, group_cfg in self.rewards.__dict__.items():
                if group_cfg is None:
                    continue
                setattr(self.rewards, group_name, manager_terms_to_dict(group_cfg))
        else:
            self.rewards = manager_terms_to_dict(self.rewards)
        self.events = manager_terms_to_dict(self.events)
        self.curriculum = manager_terms_to_dict(self.curriculum)
        self.terminations = manager_terms_to_dict(self.terminations)
        self.monitors = manager_terms_to_dict(self.monitors)

        self.run_name = "".join([])
